# Authentication
[user]
    name = Andy Dirnberger
    email = andy@dirnberger.me
[credential]
    helper = osxkeychain

# Core
[alias]
    br = branch
    ci = commit
    co = checkout
    cp = cherry-pick
    rb = rebase
    st = status
    aliases = !git config -l | grep alias | cut -c 7-
    amend = commit --amend
    graph = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
    last = diff --cached HEAD^
    ll = log --pretty=format:"%C(yellow)%h%C(cyan)%d\\ %Creset%s%Cred\\ [%cn]" --decorate --numstat
    locate = ls-tree --name-only -r HEAD
    ls = log --pretty=format:"%C(yellow)%h%C(cyan)%d\\ %Creset%s%Cred\\ [%cn]" --decorate
    missing = !git log --no-merges "$1" ^"$2"
    modified = !git ll -1
    patch = commit --patch -v
    pretty = log --oneline --decorate
    restore = !git checkout $(git rev-list -n 1 HEAD -- "$1")^ -- "$1"
    rewind = reset --soft HEAD~1
    stash = -c commit.gpgsign=false stash
    when = log --pretty=format:"%C(yellow)%h\\ %C(green)%ad%C(cyan)%d\\ %Creset%s%Cred\\ [%cn]" --decorate --date=relative
    wip = commit -m '[WIP]'
[color]
    ui = true
[color "diff-highlight"]
    newHighlight = "green bold 22"
    newNormal = "green bold"
    oldHighlight = "red bold 52"
    oldNormal = "red bold"
[commit]
    gpgsign = true
[core]
    diff = diff-highlight | less
    editor = vim
    excludesfile = ~/.gitignoreglobal
    pager = diff-highlight | less
    show = diff-highlight | less
[diff]
    algorithm = patience
    tool = Kaleidoscope
[difftool]
    prompt = false
[difftool "Kaleidoscope"]
    cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"
[include]
    # Include a file that contains user.signingkey so that a different key can
    # be used on all machines using this .gitconfig.
    path = ~/.gitsigningkey
[interactive]
    diffFilter = diff-highlight
[merge]
    tool = Kaleidoscope
[mergetool]
    keepBackup = false
    prompt = false
[mergetool "fugitive"]
    cmd = mvim -f -c \"Gdiff\" \"$MERGED\"
[mergetool "Kaleidoscope"]
    cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
    trustExitCode = true
[pull]
    rebase = true
[push]
    default = simple
[rebase]
    autoStash = true

# Plugins
[github]
    user = dirn
